# Dockerfile-gcp
#
# Image used by .github/workflows/gcp-deploy.yaml. Build context is the repo
# root (NOT api/), so all COPY paths are repo-root-relative.
#
# Functionally identical to api/Dockerfile; only the COPY paths differ.
# Keep these two in sync until api/Dockerfile is retired.
#
# WARNING: base images below are EOL Debian buster + Node 15.10.0. Artifact
# Registry vulnerability scanning will flag this. Migrating to bookworm + a
# supported Node LTS is tracked separately and is out of scope for this image.

FROM buildpack-deps:buster AS isolate
# Debian buster reached EOL on 2024-06-30; redirect apt to archive.debian.org.
RUN sed -i 's|http://deb.debian.org|http://archive.debian.org|g; s|http://security.debian.org/debian-security|http://archive.debian.org/debian-security|g' /etc/apt/sources.list && \
    sed -i '/buster-updates/d' /etc/apt/sources.list && \
    echo 'Acquire::Check-Valid-Until "false";' > /etc/apt/apt.conf.d/99no-check-valid-until
RUN apt-get update && \
    apt-get install -y --no-install-recommends git libcap-dev && \
    rm -rf /var/lib/apt/lists/* && \
    git clone https://github.com/envicutor/isolate.git /tmp/isolate/ && \
    cd /tmp/isolate && \
    git checkout af6db68042c3aa0ded80787fbb78bc0846ea2114 && \
    make -j$(nproc) install && \
    rm -rf /tmp/*

# Stage: build the Python 3.12.0 Piston package (CPython + pip libs + sitecustomize)
# This is baked into /opt/piston_pkg_cache and restored to /piston/packages on
# container start via docker-entrypoint.sh, so prod gets the libs and sandbox
# wrapper without needing a separate package repo or runtime ppman install.
FROM buildpack-deps:buster AS python-builder
RUN sed -i 's|http://deb.debian.org|http://archive.debian.org|g; s|http://security.debian.org/debian-security|http://archive.debian.org/debian-security|g' /etc/apt/sources.list && \
    sed -i '/buster-updates/d' /etc/apt/sources.list && \
    echo 'Acquire::Check-Valid-Until "false";' > /etc/apt/apt.conf.d/99no-check-valid-until
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential curl ca-certificates \
        libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev \
        libffi-dev liblzma-dev libncurses5-dev libncursesw5-dev \
        libgdbm-dev tk-dev libexpat1-dev \
        gfortran libblas-dev liblapack-dev libfreetype6-dev libpng-dev && \
    rm -rf /var/lib/apt/lists/*
COPY packages/python/3.12.0 /pkg/python/3.12.0
WORKDIR /pkg/python/3.12.0
RUN bash build.sh && \
    cd /pkg/python/3.12.0 && \
    echo "$(date +%s%3N)" > .ppman-installed && \
    # cache .env that ppman would normally generate from `source environment`
    env -i bash -c "cd /pkg/python/3.12.0 && source environment && env" \
        | grep -vE '^(PWD|OLDPWD|_|SHLVL)=' > .env

FROM node:15.10.0-buster-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN sed -i 's|http://deb.debian.org|http://archive.debian.org|g; s|http://security.debian.org/debian-security|http://archive.debian.org/debian-security|g' /etc/apt/sources.list && \
    sed -i '/buster-updates/d' /etc/apt/sources.list && \
    echo 'Acquire::Check-Valid-Until "false";' > /etc/apt/apt.conf.d/99no-check-valid-until

RUN dpkg-reconfigure -p critical dash
RUN apt-get update && \
    apt-get install -y libxml2 gnupg tar coreutils util-linux libc6-dev \
    binutils build-essential locales libpcre3-dev libevent-dev libgmp3-dev \
    libncurses6 libncurses5 libedit-dev libseccomp-dev rename procps python3 \
    libreadline-dev libblas-dev liblapack-dev libpcre3-dev libarpack2-dev \
    libfftw3-dev libglpk-dev libqhull-dev libqrupdate-dev libsuitesparse-dev \
    libsundials-dev libpcre2-dev libcap-dev && \
    rm -rf /var/lib/apt/lists/*
RUN useradd -M piston

# Create the data directory so the image is self-sufficient when no volume
# is mounted at /piston (e.g. on the first pod start before the PVC is bound,
# or in any env that forgets to mount). config.js validates that this exists,
# and the entrypoint chowns it; both must succeed or the container crash-loops.
RUN mkdir -p /piston && chown piston:piston /piston

COPY --from=isolate /usr/local/bin/isolate /usr/local/bin
COPY --from=isolate /usr/local/etc/isolate /usr/local/etc/isolate

# Bake the Python package into a cache location. The entrypoint copies it into
# /piston/packages/python/3.12.0 on container start if not already present, so
# the same image works both with and without a PVC mounted at /piston/packages.
RUN mkdir -p /opt/piston_pkg_cache/python && chown piston:piston /opt/piston_pkg_cache
COPY --from=python-builder --chown=piston:piston /pkg/python/3.12.0 /opt/piston_pkg_cache/python/3.12.0

RUN sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && locale-gen

WORKDIR /piston_api
COPY ["api/package.json", "api/package-lock.json", "./"]
RUN npm install
COPY ./api/src ./src

CMD ["/piston_api/src/docker-entrypoint.sh"]
EXPOSE 2000/tcp
