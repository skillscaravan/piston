# =============================================================================
# Piston API environment variables.
#
# Copy this file to `.env` (gitignored) and edit values for local dev.
# In production (GKE / Helm), these go in your Helm chart's env or via
# Secret Manager / ConfigMap. Do NOT commit a populated `.env`.
#
# All vars below are read by api/src/config.js. Defaults shown match the
# config defaults; uncomment to override.
# =============================================================================

# -----------------------------------------------------------------------------
# Core API
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARN | ERROR | NONE
PISTON_LOG_LEVEL=INFO

# Address:port to bind the HTTP server to. Inside the container, leave default.
PISTON_BIND_ADDRESS=0.0.0.0:2000

# Where Piston stores packages and the remote_files cache.
PISTON_DATA_DIRECTORY=/piston

# Repository index URL for installable language packages.
PISTON_REPO_URL=https://github.com/engineer-man/piston/releases/download/pkgs/index

# Maximum jobs running concurrently. Per pod.
PISTON_MAX_CONCURRENT_JOBS=64

# -----------------------------------------------------------------------------
# Sandbox runner UID/GID range (do not change unless you know why)
# -----------------------------------------------------------------------------

PISTON_RUNNER_UID_MIN=1001
PISTON_RUNNER_UID_MAX=1500
PISTON_RUNNER_GID_MIN=1001
PISTON_RUNNER_GID_MAX=1500

# -----------------------------------------------------------------------------
# Sandbox security & resource limits
# -----------------------------------------------------------------------------

# Disable network syscalls in the sandbox. KEEP TRUE in production.
PISTON_DISABLE_NETWORKING=true

# Max stdout/stderr buffer size per stage (bytes).
PISTON_OUTPUT_MAX_SIZE=1024

# Max processes per job.
PISTON_MAX_PROCESS_COUNT=64

# Max open files per job.
PISTON_MAX_OPEN_FILES=2048

# Max single-file write size (bytes).
PISTON_MAX_FILE_SIZE=10000000

# -----------------------------------------------------------------------------
# Per-stage timeouts (milliseconds)
# -----------------------------------------------------------------------------

PISTON_COMPILE_TIMEOUT=10000
PISTON_RUN_TIMEOUT=3000
PISTON_COMPILE_CPU_TIME=10000
PISTON_RUN_CPU_TIME=3000

# Memory caps in bytes. -1 = unlimited.
PISTON_COMPILE_MEMORY_LIMIT=-1
PISTON_RUN_MEMORY_LIMIT=-1

# Per-language overrides as JSON (rarely needed).
# PISTON_LIMIT_OVERRIDES={"python":{"run_timeout":15000}}

# -----------------------------------------------------------------------------
# Production-realistic limits for dataset workloads (uncomment as needed).
# The defaults above are upstream Piston's defaults and are sized for
# hello-world snippets. For pandas-on-CSV training questions, raise the
# wall/CPU timeouts, memory cap, and stdout buffer:
#
#   PISTON_RUN_TIMEOUT=15000          # 15s wall clock
#   PISTON_RUN_CPU_TIME=10000         # 10s CPU
#   PISTON_RUN_MEMORY_LIMIT=536870912 # 512 MB
#   PISTON_OUTPUT_MAX_SIZE=2097152    # 2 MB stdout cap
#   PISTON_COMPILE_TIMEOUT=15000      # not used for python; harmless
#
# Tune against actual student submissions. Keep these as DoS protection;
# don't set obscene values just to silence timeouts.
# -----------------------------------------------------------------------------

# =============================================================================
# remote_files: signed-URL dataset attachment.
#
# When enabled, callers can pass `remote_files: [{url, name, version}]` on
# /api/v2/execute. Piston fetches the URL, caches it, and materializes it in
# the sandbox CWD before running. Sandbox networking stays OFF.
# See docs/remote-files.md.
# =============================================================================

# Master feature flag. Off by default.
PISTON_REMOTE_FILES_ENABLED=false

# Comma-separated list of allowed hostnames (the SSRF guard).
# Add raw.githubusercontent.com when running tests/remote_files.py.
PISTON_REMOTE_FILES_HOST_ALLOWLIST=storage.googleapis.com

# On-disk cache location. MUST be on the same filesystem as
# /var/local/lib/isolate. See docs/remote-files.md#filesystem-requirement.
PISTON_REMOTE_FILES_CACHE_DIR=/piston/remote-files-cache

# Hard cap on total cache bytes; LRU evicts past this. (5 GB)
PISTON_REMOTE_FILES_CACHE_MAX_BYTES=5368709120

# Per-object hard cap. Fetches exceeding this are aborted. (100 MB)
PISTON_REMOTE_FILES_MAX_OBJECT_SIZE=104857600

# Sum-of-all-remote_files-per-request cap. (200 MB)
PISTON_REMOTE_FILES_MAX_TOTAL_BYTES=209715200

# Per-object fetch timeout in ms.
PISTON_REMOTE_FILES_FETCH_TIMEOUT_MS=30000
